# Local flavor — your machine's backend
# Android emulator : API_BASE_URL=http://10.0.2.2:8080/api
# iOS simulator    : API_BASE_URL=http://localhost:8080/api
# Physical device  : API_BASE_URL=http://<your-lan-ip>:8080/api
# Run: flutter run --flavor local --dart-define-from-file=assets/env/app.local.env
#      or override URL: flutter run --flavor local --dart-define-from-file=assets/env/app.local.env --dart-define=API_BASE_URL=http://10.0.2.2:8080/api
APP_FLAVOR=local
API_BASE_URL=http://localhost:8080/api
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
GOOGLE_MAPS_API_KEY=
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
